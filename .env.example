# ─── Threads API ───────────────────────────────────────────────
# Your Threads User ID (returned after OAuth)
THREADS_USER_ID=

# Your long-lived Threads access token (from Meta OAuth flow)
THREADS_ACCESS_TOKEN=

# ─── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── App ───────────────────────────────────────────────────────
PORT=3000

# How often to poll tracked accounts for new posts (in minutes)
POLL_INTERVAL_MINUTES=15
